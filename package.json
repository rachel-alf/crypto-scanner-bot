{
  "name": "tradbot",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "start": "node dist/src/spot/bot-spot.js",
    "dev": "tsx src/spot/bot-spot.ts",
    "launch": "node dist/src/spot/launcher-spot.js",
    "launch:dev": "tsx src/spot/launcher-spot.ts",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json}\"",
    "dev:scanner": "ts-node src/scanner/scanner.ts",
    "dev:spot": "ts-node src/spot/bot-spot.ts",
    "dev:futures": "ts-node src/futures/launcher-future.ts",
    "start:debug": "node dist/src/futures/launcher-future.js --debug-cooldown",
    "pm2:start": "npm run build && pm2 start ecosystem.config.js",
    "pm2:restart": "npm run build && pm2 restart all",
    "pm2:stop": "pm2 stop all",
    "pm2:delete": "pm2 delete all",
    "pm2:logs": "pm2 logs",
    "pm2:monit": "pm2 monit",
    "pm2:list": "pm2 list",
    "pm2:save": "pm2 save && pm2 startup",
    "pm2:restart:scanner": "npm run build && pm2 restart scanner",
    "pm2:restart:spot": "npm run build && pm2 restart spot-trader",
    "pm2:restart:futures-1": "npm run build && pm2 restart futures-trader-1",
    "pm2:restart:futures-2": "npm run build && pm2 restart futures-trader-2",
    "pm2:restart:futures": "npm run build && pm2 restart futures-trader-1 futures-trader-2",
    "pm2:logs:scanner": "pm2 logs scanner --lines 100",
    "pm2:logs:spot": "pm2 logs spot-trader --lines 100",
    "pm2:logs:futures-1": "pm2 logs futures-trader-1 --lines 100",
    "pm2:logs:futures-2": "pm2 logs futures-trader-2 --lines 100",
    "pm2:flush": "pm2 flush",
    "pm2:info": "pm2 info",
    "check:signals": "ts-node src/test/check-signals.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^9.39.2",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.0",
    "@types/node": "^25.5.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.50.0",
    "@typescript-eslint/parser": "^8.50.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.5.0",
    "prettier": "^3.7.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.0"
  },
  "dependencies": {
    "ccxt": "^4.5.34",
    "cli-table3": "^0.6.5",
    "dotenv": "^17.2.3",
    "rotating-file-stream": "^3.2.7",
    "technicalindicators": "^3.1.0",
    "ws": "^8.18.3"
  }
}
